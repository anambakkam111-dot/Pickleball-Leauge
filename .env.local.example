# Copy this file to .env.local and fill in your admin password.
# Then run: vercel dev   (NOT npm run dev — that doesn't serve the API routes)
#
# Option A — plain text password (simpler):
ADMIN_PASSWORD=your_password_here

# Option B — SHA-256 hash (slightly more secure; prevents plaintext in env):
# Generate with: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('your_password_here').digest('hex'))"
# ADMIN_PASSWORD_HASH=e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855

# Optional — separate HMAC key for session tokens (defaults to the password if not set):
# SESSION_SECRET=some_random_long_string
